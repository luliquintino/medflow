// Med Flow — Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ShiftType {
  TWELVE_HOURS
  TWENTY_FOUR_HOURS
  NIGHT
}

enum ShiftStatus {
  CONFIRMED
  SIMULATED
  CANCELLED
}

enum RiskLevel {
  SAFE
  MODERATE
  HIGH
}

enum SubscriptionPlan {
  ESSENTIAL
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum ShiftTemplateType {
  DIURNO_12H
  NOTURNO_12H
  PLANTAO_24H
  PERSONALIZADO
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String
  gender            Gender?
  crm               String?
  passwordHash      String?
  googleId          String?  @unique
  avatarUrl         String?
  isEmailVerified   Boolean  @default(false)
  emailVerifyToken  String?
  resetPasswordToken String?
  resetPasswordExpiry DateTime?
  onboardingCompleted Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  financialProfile  FinancialProfile?
  workProfile       WorkProfile?
  shifts            Shift[]
  riskHistory       RiskHistory[]
  subscription      Subscription?
  wearableData      WearableData[]
  refreshTokens     RefreshToken[]
  hospitals         Hospital[]

  @@map("users")
}

// ─────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// FINANCIAL PROFILE
// ─────────────────────────────────────────────

model FinancialProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  savingsGoal         Float    @default(0)
  averageShiftValue   Float    @default(0)
  minimumMonthlyGoal  Float    @default(0)
  idealMonthlyGoal    Float    @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("financial_profiles")
}

// ─────────────────────────────────────────────
// WORK PROFILE
// ─────────────────────────────────────────────

model WorkProfile {
  id                    String      @id @default(uuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  shiftTypes            ShiftType[]
  maxWeeklyHours        Int?        // optional personal limit
  preferredRestDays     Int[]       // 0=Sunday ... 6=Saturday
  maxConsecutiveShifts  Int         @default(3)
  maxConsecutiveNights  Int         @default(2)

  // Custos energéticos por tipo de plantão (editáveis pelo usuário)
  energyCostDiurno      Float       @default(1.0)   // 12h diurno
  energyCostNoturno     Float       @default(1.5)   // 12h noturno
  energyCost24h         Float       @default(2.5)   // 24h

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@map("work_profiles")
}

// ─────────────────────────────────────────────
// SHIFTS
// ─────────────────────────────────────────────

model Shift {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  hospitalId  String?
  hospital    Hospital?   @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  date        DateTime
  endDate     DateTime
  type        ShiftType
  hours       Int         // 12 or 24
  value       Float
  location    String
  notes       String?
  status      ShiftStatus @default(CONFIRMED)
  realized    Boolean?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, date])
  @@map("shifts")
}

// ─────────────────────────────────────────────
// HOSPITAL
// ─────────────────────────────────────────────

model Hospital {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  city       String?
  state      String?
  notes      String?
  paymentDay Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates ShiftTemplate[]
  shifts    Shift[]

  @@index([userId])
  @@map("hospitals")
}

// ─────────────────────────────────────────────
// SHIFT TEMPLATE
// ─────────────────────────────────────────────

model ShiftTemplate {
  id              String            @id @default(uuid())
  hospitalId      String
  hospital        Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  name            String?
  type            ShiftTemplateType
  durationInHours Int
  defaultValue    Float
  isNightShift    Boolean           @default(false)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([hospitalId])
  @@map("shift_templates")
}

// ─────────────────────────────────────────────
// RISK HISTORY
// ─────────────────────────────────────────────

model RiskHistory {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  riskLevel       RiskLevel
  riskScore       Float
  triggerRules    String[]  // which rules were triggered
  recommendation  String
  periodStart     DateTime
  periodEnd       DateTime
  hoursIn5Days    Float
  hoursInWeek     Float
  consecutiveNights Int
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("risk_history")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                 SubscriptionPlan   @default(ESSENTIAL)
  status               SubscriptionStatus @default(ACTIVE)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// WEARABLE DATA (structure ready for future)
// ─────────────────────────────────────────────

model WearableData {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  source         String   // "apple_health" | "garmin" | "oura" | "whoop" | "mock"
  recordedAt     DateTime

  hrv            Float?   // Heart Rate Variability (ms)
  sleepScore     Float?   // 0–100
  sleepHours     Float?
  recoveryScore  Float?   // 0–100
  restingHR      Float?
  stressLevel    Float?

  rawData        Json?    // provider-specific payload

  createdAt      DateTime @default(now())

  @@index([userId, recordedAt])
  @@map("wearable_data")
}
