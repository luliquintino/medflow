# ─────────────────────────────────────────────
# Med Flow Backend — Environment Variables
# Copy to .env and fill in the values
# ─────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3001
APP_URL=https://medflow-backend.railway.app
FRONTEND_URL=https://medflow.vercel.app

# Database (PostgreSQL)
# Railway: copy connection string from your Railway PostgreSQL service
DATABASE_URL="postgresql://user:password@host:5432/medflow"

# JWT
# Generate secrets with: openssl rand -hex 64
JWT_SECRET=your-super-secure-jwt-secret-min-64-chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-min-64-chars
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Stripe
# Keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ESSENTIAL=price_...
STRIPE_PRICE_PRO=price_...

# Email (Resend)
# Sign up at https://resend.com and create an API key
# Free tier: 100 emails/day, 3000 emails/month
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Med Flow <onboarding@resend.dev>"

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${APP_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://medflow-backend.railway.app/api/v1/auth/google/callback

# Trial Period (days)
TRIAL_DAYS=14
