# ─────────────────────────────────────────────
# Med Flow Backend — Environment Variables
# Copy to .env and fill in the values
# ─────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3001
APP_URL=https://medflow-backend.railway.app
FRONTEND_URL=https://medflow.vercel.app

# Database (PostgreSQL)
# Railway: copy connection string from your Railway PostgreSQL service
DATABASE_URL="postgresql://user:password@host:5432/medflow"

# JWT
# Generate secrets with: openssl rand -hex 64
JWT_SECRET=your-super-secure-jwt-secret-min-64-chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-min-64-chars
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Stripe
# Keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ESSENTIAL=price_...
STRIPE_PRICE_PRO=price_...

# Email (SMTP)
# Gmail: enable 2FA, then create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Med Flow <no-reply@medflow.app>"

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${APP_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://medflow-backend.railway.app/api/v1/auth/google/callback

# Trial Period (days)
TRIAL_DAYS=14
