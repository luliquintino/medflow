{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "/usr/local/bin/npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3002"],
      "port": 3002,
      "cwd": "${workspaceRoot}/frontend",
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    {
      "name": "backend",
      "runtimeExecutable": "/usr/local/bin/npm",
      "runtimeArgs": ["run", "start:dev"],
      "port": 3001,
      "autoPort": true,
      "cwd": "${workspaceRoot}/backend",
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  ]
}
